# Wrangler local state cache — per-machine artifacts, don't commit.
.wrangler/

# Env files with secrets — we use `wrangler secret put` instead, but
# belt-and-suspenders in case someone creates one locally.
.env
.env.*
!.env.example

# Node bits if anyone ever npm installs here.
node_modules/

# Local copy of the admin token (set by deploy.sh, read by
# provision-tenant.sh). chmod 600. NEVER commit.
.admin-token
